server:
  port: 8089
  read_timeout_ms: 5000
  write_timeout_ms: 0
  idle_timeout_ms: 60000

proxy:
  timeout_ms: 0

security:
  jwt:
    enabled: true
    issuer: "https://issuer.example.com"
    audience: "gateway-clients"
    hmac_secret: "change-me-in-prod"

rate_limit:
  enabled: true
  rps: 20
  burst: 40
  by_api_key_header: "X-API-Key"

routes:
  - name: users
    methods: ["GET", "POST"]
    path_prefix: "/users"
    upstream: "http://localhost:9001"
    trim_path: true
    rate_limit:
      enabled: true
      rps: 20
      burst: 40

  - name: crg
    methods: ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    path_prefix: "/crg/api"
    upstream: "http://localhost:8082"
    trim_path: true
    rate_limit:
      enabled: true
      rps: 20
      burst: 40
  
  - name: crg-fe
    methods: ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    path_prefix: "/crg"
    upstream: "http://localhost:5173"
    trim_path: false
    rate_limit:
      enabled: false
