server:
  port: 8089
  read_timeout_ms: 5000
  write_timeout_ms: 0
  idle_timeout_ms: 60000
  tls:
    enabled: false
    cert_file: ""
    key_file: ""

proxy:
  timeout_ms: 0

telemetry:
  enabled: false
  service_name: "api-gateway"
  otlp_endpoint: "localhost:4317"
  insecure: true

security:
  jwt:
    enabled: true
    issuer: "https://issuer.example.com"
    audience: "gateway-clients"
    hmac_secret: ""

admin:
  enabled: false
  api_key: ""

rate_limit:
  enabled: true
  rps: 20
  burst: 40
  by_api_key_header: "X-API-Key"
  backend: "memory"
  redis_address: "localhost:6379"
  redis_password: ""
  redis_db: 0
  redis_key_prefix: "gateway:rl"

routes:
  # Single upstream (backward compatible).
  - name: users
    methods: ["GET", "POST"]
    path_prefix: "/users"
    upstream: "http://localhost:9001"
    trim_path: true
    forward_headers: ["X-Request-ID", "X-Correlation-ID"]
    rate_limit:
      enabled: true
      rps: 20
      burst: 40

  # Multiple upstreams with weighted load balancing and passive health checks.
  - name: orders
    methods: ["GET", "POST"]
    path_prefix: "/orders"
    trim_path: true
    load_balancing: "weighted"   # round_robin (default) | weighted | random
    upstreams:
      - url: "http://localhost:9101"
        weight: 3
      - url: "http://localhost:9102"
        weight: 1
    health_check:
      passive:
        enabled: true
        failure_threshold: 3   # eject after N consecutive failures
        cooldown_ms: 10000     # re-probe (half-open) after this window
    retry:
      enabled: true
      max_attempts: 2          # retries fail over to another upstream
      backoff_ms: 100
